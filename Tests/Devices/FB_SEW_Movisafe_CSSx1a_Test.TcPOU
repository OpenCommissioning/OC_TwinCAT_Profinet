    <Method Name="Test_ProcessDataControl" Id="{1907765c-79c0-0519-015b-3651dbae9588}">
      <Declaration><![CDATA[METHOD Test_ProcessDataControl : REFERENCE TO FB_Test
VAR
	fbDevice 					: FB_SEW_Movisafe_CSSx1a;

	stExpectedControlData 		: ST_SEW_Movisafe_CSSx1a_Control;		
	stExpectedControlDataSwap	: ST_SEW_Movisafe_CSSx1a_Control;	
	stActualControlData			: ST_SEW_Movisafe_CSSx1a_Control;	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Process data to control structure');

//Arrange
stExpectedControlData.b0_0_STO 				:= TRUE;
stExpectedControlData.b0_1_SLI 				:= TRUE;
stExpectedControlData.b0_2_SBT 				:= FALSE;
stExpectedControlData.b0_3_Reserved		    := TRUE;
stExpectedControlData.b0_4_MutingEncErr	    := TRUE;
stExpectedControlData.b0_5_TestModeActice	:= TRUE;
stExpectedControlData.b0_6_AckFDI			:= TRUE;
stExpectedControlData.b0_7_AckError		    := FALSE;
stExpectedControlData.b1_0_F_DO0			:= FALSE;
stExpectedControlData.b1_1_F_DO1			:= TRUE;
stExpectedControlData.b1_2_Reserved		    := TRUE;
stExpectedControlData.b1_3_Reserved		    := FALSE;
stExpectedControlData.b1_4_Reserved		    := TRUE;
stExpectedControlData.b1_5_Reserved		    := TRUE;
stExpectedControlData.b1_6_Reserved		    := FALSE;
stExpectedControlData.b1_7_Reserved		    := TRUE;
stExpectedControlData.b2_0_SOS1			    := TRUE;
stExpectedControlData.b2_1_Reserved		    := FALSE;
stExpectedControlData.b2_2_SSx1			    := FALSE;
stExpectedControlData.b2_3_SSx2			    := FALSE;
stExpectedControlData.b2_4_SDI1			    := TRUE;
stExpectedControlData.b2_5_SDI2			    := TRUE;
stExpectedControlData.b2_6_SLI1			    := TRUE;
stExpectedControlData.b2_7_SLI2			    := FALSE;
stExpectedControlData.b3_0_SLS1			    := TRUE;
stExpectedControlData.b3_1_SLS2			    := TRUE;
stExpectedControlData.b3_2_SLS3			    := TRUE;
stExpectedControlData.b3_3_SLS4			    := TRUE;
stExpectedControlData.b3_4_SSR1			    := TRUE;
stExpectedControlData.b3_5_SSR2			    := TRUE;
stExpectedControlData.b3_6_Reserved		    := TRUE;
stExpectedControlData.b3_7_Reserved		    := FALSE;
stExpectedControlData.b4_0_SLA1			    := FALSE;
stExpectedControlData.b4_1_SLA2			    := TRUE;
stExpectedControlData.b4_2_Reserved		    := TRUE;
stExpectedControlData.b4_3_Reserved		    := TRUE;
stExpectedControlData.b4_4_Reserved		    := TRUE;
stExpectedControlData.b4_5_Reserved		    := FALSE;
stExpectedControlData.b4_6_Reserved		    := TRUE;
stExpectedControlData.b4_7_Reserved		    := FALSE;

fbDevice.pControl := ADR(stExpectedControlData);

//Act
fbDevice.GetControlData();

stActualControlData := fbDevice.stControl;

//Assert
AssertEquals(Expected := stExpectedControlData,
             Actual := stActualControlData,
             Message := 'ControlData is not correct');
	 			 			 
TEST_FINISHED();


