stExpectedStatusData.b4_7_Reserved		    := FALSE;
stExpectedStatusData.b5_0_Reserved		    := FALSE;
stExpectedStatusData.b5_1_Reserved		    := FALSE;
stExpectedStatusData.b5_2_Reserved		    := FALSE;
stExpectedStatusData.b5_3_Reserved		    := FALSE;
stExpectedStatusData.b5_4_Reserved		    := FALSE;
stExpectedStatusData.b5_5_Reserved		    := FALSE;
stExpectedStatusData.b5_6_Reserved		    := FALSE;
stExpectedStatusData.b5_7_Reserved	        := FALSE;
	
//Act

fbDevice.stControl := stSetControl;
fbDevice.Cycle();
stActualStatusData := fbDevice.stStatus ;

//Assert

AssertEquals(Expected := stExpectedStatusData,
             Actual := stActualStatusData,
             Message := 'Status is not correct');
	 					 			 
TEST_FINISHED();

