//Assert
IF (nStatusExpected <> fbFSM.nStatus) THEN
	AssertEquals_BOOL(stStatusExpected.b0_ReadyToSwitchOn, fbFSM.stZSW1.b0_ReadyToSwitchOn, 'b0_ReadyToSwitchOn: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b1_ReadyForOperation, fbFSM.stZSW1.b1_ReadyForOperation, 'b1_ReadyForOperation: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b2_OperationEnabled, fbFSM.stZSW1.b2_OperationEnabled, 'b2_OperationEnabled: AssertEquals not returning expected value');	
	AssertEquals_BOOL(stStatusExpected.b6_SwitchingOnInhibited, fbFSM.stZSW1.b6_SwitchingOnInhibited, 'b6_SwitchingOnInhibited: AssertEquals not returning expected value');	
END_IF

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestState_S4" Id="{eb2efc53-7797-0db0-0d46-8c839adaf33d}">
      <Declaration><![CDATA[METHOD TestState_S4 : BOOL
