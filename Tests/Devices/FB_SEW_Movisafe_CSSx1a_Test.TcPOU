stExpectedStatusData.b0_6_Warning		    := FALSE;
stExpectedStatusData.b0_7_ErrorState		:= FALSE;
stExpectedStatusData.b1_0_F_DI0			    := FALSE;
stExpectedStatusData.b1_1_F_DI1			    := FALSE;
stExpectedStatusData.b1_2_F_DI2			    := FALSE;
stExpectedStatusData.b1_3_F_DI3			    := FALSE;
