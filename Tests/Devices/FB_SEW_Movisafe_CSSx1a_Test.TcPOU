stExpectedControlData.b2_4_SDI1			    := TRUE;
stExpectedControlData.b2_5_SDI2			    := TRUE;
stExpectedControlData.b2_6_SLI1			    := TRUE;
stExpectedControlData.b2_7_SLI2			    := FALSE;
stExpectedControlData.b3_0_SLS1			    := TRUE;
stExpectedControlData.b3_1_SLS2			    := TRUE;
stExpectedControlData.b3_2_SLS3			    := TRUE;
stExpectedControlData.b3_3_SLS4			    := TRUE;
stExpectedControlData.b3_4_SSR1			    := TRUE;
stExpectedControlData.b3_5_SSR2			    := TRUE;
stExpectedControlData.b3_6_Reserved		    := TRUE;
stExpectedControlData.b3_7_Reserved		    := FALSE;
stExpectedControlData.b4_0_SLA1			    := FALSE;
stExpectedControlData.b4_1_SLA2			    := TRUE;
stExpectedControlData.b4_2_Reserved		    := TRUE;
stExpectedControlData.b4_3_Reserved		    := TRUE;
stExpectedControlData.b4_4_Reserved		    := TRUE;
stExpectedControlData.b4_5_Reserved		    := FALSE;
stExpectedControlData.b4_6_Reserved		    := TRUE;
stExpectedControlData.b4_7_Reserved		    := FALSE;
	
F_Memcpy(ADR(stExpectedControlDataSwap), ADR(stExpectedControlData), SIZEOF(stExpectedControlData), TRUE);

fbDevice.pControl := ADR(stExpectedControlDataSwap);

fbDevice.stConfig.bSwapProcessData := TRUE;

//Act
fbDevice.GetControlData();

stActualControlData := fbDevice.stControl;

//Assert
AssertEquals(Expected := stExpectedControlData,
             Actual := stActualControlData,
             Message := 'CW1 is not correct');

			 			 
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="Test_ProcessDataStatus" Id="{366b7906-2edf-0384-16da-08a251f51e01}">
