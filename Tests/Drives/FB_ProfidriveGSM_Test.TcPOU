<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_ProfidriveGSM_Test" Id="{f35b0c2b-bf7b-08eb-1441-1129517b119a}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ProfidriveGSM_Test EXTENDS TcUnit.FB_TestSuite

]]></Declaration>
    <Implementation>
      <ST><![CDATA[TestState_S0();
TestState_S1();
TestState_S2();
TestState_S3();
TestState_S4();
TestState_S51();
TestState_S52();

TestTransitions_S0();
TestTransitions_S1();
TestTransitions_S2();
TestTransitions_S3();
TestTransitions_S4();
TestTransitions_S51();
TestTransitions_S52();]]></ST>
    </Implementation>
    <Method Name="TestState_S0" Id="{0722bab6-5316-0ca8-2a8f-9bc8f87e4ce0}">
      <Declaration><![CDATA[METHOD TestState_S0 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Set State S0');

//Arrange
fbFSM.eState := E_ProfidriveGSM_State.S0_Disabled;

stStatusExpected.b0_ReadyToSwitchOn 		:= FALSE;				
stStatusExpected.b1_ReadyForOperation 		:= FALSE;				
stStatusExpected.b2_OperationEnabled 		:= FALSE;
stStatusExpected.b6_SwitchingOnInhibited 	:= FALSE;
MEMCPY(ADR(nStatusExpected), ADR(stStatusExpected), 2);

//Act
fbFSM();

//Assert
IF (nStatusExpected <> fbFSM.nStatus) THEN
	AssertEquals_BOOL(stStatusExpected.b0_ReadyToSwitchOn, fbFSM.stZSW1.b0_ReadyToSwitchOn, 'b0_ReadyToSwitchOn: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b1_ReadyForOperation, fbFSM.stZSW1.b1_ReadyForOperation, 'b1_ReadyForOperation: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b2_OperationEnabled, fbFSM.stZSW1.b2_OperationEnabled, 'b2_OperationEnabled: AssertEquals not returning expected value');	
	AssertEquals_BOOL(stStatusExpected.b6_SwitchingOnInhibited, fbFSM.stZSW1.b6_SwitchingOnInhibited, 'b6_SwitchingOnInhibited: AssertEquals not returning expected value');	
END_IF

TEST_FINISHED();

]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestState_S1" Id="{21e4e4c6-7feb-0913-2530-a3403cbcc57a}">
      <Declaration><![CDATA[METHOD TestState_S1 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Set State S1');

//Arrange
fbFSM.eState := E_ProfidriveGSM_State.S1_SwitchingOnInhibited;

stStatusExpected.b0_ReadyToSwitchOn 		:= FALSE;				
stStatusExpected.b1_ReadyForOperation 		:= FALSE;				
stStatusExpected.b2_OperationEnabled 		:= FALSE;
stStatusExpected.b6_SwitchingOnInhibited 	:= TRUE;
MEMCPY(ADR(nStatusExpected), ADR(stStatusExpected), 2);

//Act
fbFSM();

//Assert
IF (nStatusExpected <> fbFSM.nStatus) THEN
	AssertEquals_BOOL(stStatusExpected.b0_ReadyToSwitchOn, fbFSM.stZSW1.b0_ReadyToSwitchOn, 'b0_ReadyToSwitchOn: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b1_ReadyForOperation, fbFSM.stZSW1.b1_ReadyForOperation, 'b1_ReadyForOperation: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b2_OperationEnabled, fbFSM.stZSW1.b2_OperationEnabled, 'b2_OperationEnabled: AssertEquals not returning expected value');	
	AssertEquals_BOOL(stStatusExpected.b6_SwitchingOnInhibited, fbFSM.stZSW1.b6_SwitchingOnInhibited, 'b6_SwitchingOnInhibited: AssertEquals not returning expected value');	
END_IF

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestState_S2" Id="{4fb6cd64-4731-0227-14fa-4933a49e4a58}">
      <Declaration><![CDATA[METHOD TestState_S2 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Set State S2');

//Arrange
fbFSM.eState := E_ProfidriveGSM_State.S2_ReadyForSwitchingOn;

stStatusExpected.b0_ReadyToSwitchOn 		:= TRUE;				
stStatusExpected.b1_ReadyForOperation 		:= FALSE;				
stStatusExpected.b2_OperationEnabled 		:= FALSE;
stStatusExpected.b6_SwitchingOnInhibited 	:= FALSE;
MEMCPY(ADR(nStatusExpected), ADR(stStatusExpected), 2);

//Act
fbFSM();

//Assert
IF (nStatusExpected <> fbFSM.nStatus) THEN
	AssertEquals_BOOL(stStatusExpected.b0_ReadyToSwitchOn, fbFSM.stZSW1.b0_ReadyToSwitchOn, 'b0_ReadyToSwitchOn: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b1_ReadyForOperation, fbFSM.stZSW1.b1_ReadyForOperation, 'b1_ReadyForOperation: AssertEquals not returning expected value');
	AssertEquals_BOOL(stStatusExpected.b2_OperationEnabled, fbFSM.stZSW1.b2_OperationEnabled, 'b2_OperationEnabled: AssertEquals not returning expected value');	
	AssertEquals_BOOL(stStatusExpected.b6_SwitchingOnInhibited, fbFSM.stZSW1.b6_SwitchingOnInhibited, 'b6_SwitchingOnInhibited: AssertEquals not returning expected value');	
END_IF

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestState_S3" Id="{c3cc8a49-e00d-0a3c-0091-1a9173012426}">
      <Declaration><![CDATA[METHOD TestState_S3 : BOOL
