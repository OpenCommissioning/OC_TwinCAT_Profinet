  <DUT Name="ST_MovisafeCSBx1a_Status" Id="{f1742eb9-6ea2-0715-3ddc-1b7cbe55dd64}">
    <Declaration><![CDATA[{attribute 'pack_mode' := '1'}
TYPE ST_MovisafeCSBx1a_Status :
STRUCT
