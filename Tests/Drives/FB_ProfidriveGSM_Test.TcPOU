    <Method Name="TestTransitions_S0" Id="{2cf2b562-f51d-0d29-3dc8-40331aa2da09}">
      <Declaration><![CDATA[METHOD TestTransitions_S0 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Transition S0>S0');

//Arrange
fbFSM.bPowerOn := FALSE;
fbFSM.eState := E_ProfidriveGSM_State.S0_Disabled;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S0_Disabled, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S0>S1');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S0_Disabled;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S1_SwitchingOnInhibited, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();

]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTransitions_S1" Id="{2a966d2a-86e5-0a57-19ef-7d9154ededd2}">
      <Declaration><![CDATA[METHOD TestTransitions_S1 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Transition S1>S2');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S1_SwitchingOnInhibited;

fbFSM.stSTW1.b0_On 				:= FALSE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S2_ReadyForSwitchingOn, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();

]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTransitions_S2" Id="{45938320-5191-0c9a-0945-99084c0adb67}">
      <Declaration><![CDATA[METHOD TestTransitions_S2 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Transition S2>S1 Case_1');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S2_ReadyForSwitchingOn;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= FALSE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S1_SwitchingOnInhibited, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S2>S1 Case_2');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S2_ReadyForSwitchingOn;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= FALSE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S1_SwitchingOnInhibited, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S2 Still');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S2_ReadyForSwitchingOn;

fbFSM.stSTW1.b0_On 				:= FALSE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S2_ReadyForSwitchingOn, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S2>S3');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S2_ReadyForSwitchingOn;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S3_SwitchedOn, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();

]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTransitions_S3" Id="{e6c30110-0cba-0a05-3236-ecfd0aa2490c}">
      <Declaration><![CDATA[METHOD TestTransitions_S3 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Transition S3>S1 Case_1');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S3_SwitchedOn;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= FALSE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S1_SwitchingOnInhibited, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S3>S1 Case_2');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S3_SwitchedOn;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= FALSE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S1_SwitchingOnInhibited, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S3 Still');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S3_SwitchedOn;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;
fbFSM.stSTW1.b3_EnableOperation  := FALSE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S3_SwitchedOn, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S3>S2');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S3_SwitchedOn;

fbFSM.stSTW1.b0_On 				:= FALSE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S2_ReadyForSwitchingOn, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S3>S4');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S3_SwitchedOn;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;
fbFSM.stSTW1.b3_EnableOperation  := TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S4_Operation, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();

]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTransitions_S4" Id="{ce52dda4-01c8-0635-35d0-2b4cc0c49e96}">
      <Declaration><![CDATA[METHOD TestTransitions_S4 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Transition S4>S1');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S4_Operation;

fbFSM.stSTW1.b0_On 				:= FALSE;
fbFSM.stSTW1.b1_CoastStop 		:= FALSE;
fbFSM.stSTW1.b2_QuickStop 		:= FALSE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S1_SwitchingOnInhibited, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S4>S52');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S4_Operation;

fbFSM.stSTW1.b0_On 				:= FALSE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= FALSE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S52_QuickStop, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S4>S51');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S4_Operation;

fbFSM.stSTW1.b0_On 				:= FALSE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;
fbFSM.stSTW1.b3_EnableOperation 	:= FALSE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S51_RampStop, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S4>S3');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S4_Operation;

fbFSM.stSTW1.b0_On 				:= TRUE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;
fbFSM.stSTW1.b3_EnableOperation 	:= FALSE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S3_SwitchedOn, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();

]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestTransitions_S51" Id="{03057e99-f4d5-0ba5-2481-acd61d83d47a}">
      <Declaration><![CDATA[METHOD TestTransitions_S51 : BOOL
VAR
	fbFSM 				: FB_ProfidriveGSM;
	stStatusExpected	: ST_ProfiidriveGSM_ZSW1;
	nStatusExpected 	: WORD;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('Transition S51 Still');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S51_RampStop;

fbFSM.bStandstill					:= FALSE;
fbFSM.stSTW1.b0_On 				:= FALSE;
fbFSM.stSTW1.b1_CoastStop 		:= TRUE;
fbFSM.stSTW1.b2_QuickStop 		:= TRUE;
fbFSM.stSTW1.b3_EnableOperation 	:= TRUE;

//Act
fbFSM();

//Assert
AssertEquals_INT(E_ProfidriveGSM_State.S51_RampStop, fbFSM.eState, 'eState: AssertEquals not returning expected value');

TEST_FINISHED();


TEST('Transition S51>S1');

//Arrange
fbFSM.bPowerOn := TRUE;
fbFSM.eState := E_ProfidriveGSM_State.S51_RampStop;

fbFSM.bStandstill					:= FALSE;
fbFSM.stSTW1.b0_On 				:= FALSE;
